# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME="E-Billing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ebilling_db
DB_USERNAME=ebilling_user
DB_PASSWORD=your_secure_password_here

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================
# CACHE & SESSION
# ============================================
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ============================================
# MAIL CONFIGURATION
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ebilling.local"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# EXTERNAL SERVICES (Update with your keys)
# ============================================
# Payment Gateway (Xendit)
XENDIT_API_KEY=xnd_development_xxxxx
XENDIT_WEBHOOK_KEY=xxxxx

# WhatsApp Gateway
WHATSAPP_API_URL=http://localhost:3000
WHATSAPP_API_KEY=your_api_key

# Mikrotik Router
MIKROTIK_HOST=your_mikrotik_ip
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_password
MIKROTIK_PORT=8728

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================
# TELESCOPE (Debug Tool)
# ============================================
TELESCOPE_ENABLED=true

# ============================================
# SANCTUM (API Authentication)
# ============================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000
SANCTUM_ENCRYPT_COOKIES=false

